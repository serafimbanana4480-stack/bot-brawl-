# ============================================================================
# Environment Variables — Brawl Stars Bot
# ============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================================

# --- API / Server ---
API_HOST=127.0.0.1
API_PORT=8003
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
API_ENABLE_SWAGGER=true

# --- Emulator / ADB ---
ADB_PATH=adb
ADB_PORT=5554
EMULATOR_TYPE=bluestacks
EMULATOR_WINDOW_TITLE=BlueStacks App Player

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/brawl_bot.log
LOG_MAX_BYTES=10000000
LOG_BACKUP_COUNT=5

# --- Vision / Models ---
YOLO_MODEL_PATH=models/yolo/brawlstars_yolov8.pt
BRAWLER_ID_MODEL_PATH=models/yolo/brawler_id.pt
VISION_CONFIDENCE_THRESHOLD=0.37
VISION_NMS_IOU_THRESHOLD=0.45

# --- Safety / Anti-ban ---
SAFETY_MAX_TROPHIES=400
SAFETY_WARNING_TROPHIES=380
SAFETY_MAX_SESSION_HOURS=3.0
SAFETY_MIN_APM=20
SAFETY_MAX_APM=60
SAFETY_BREAK_DURATION_MIN=300
SAFETY_BREAK_DURATION_MAX=900
SAFETY_AUTO_STOP_ON_DETECTION=true

# --- Dashboard ---
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8765
DASHBOARD_AUTO_START=true

# --- Performance ---
PERFORMANCE_TARGET_FPS=30
PERFORMANCE_SCREENSHOT_INTERVAL_MS=100
PERFORMANCE_ACTION_COOLDOWN_MS=50
